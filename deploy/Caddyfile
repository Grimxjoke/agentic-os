:18080 {
    encode zstd gzip

    # Orbit OS — persistent PI/Codex control plane
    @orbit {
        path /orbit /orbit/*
    }
    reverse_proxy @orbit http://127.0.0.1:4173

    # Grafana
    @grafana {
        path /grafana/*
    }
    reverse_proxy @grafana http://127.0.0.1:3001

    # Chat (Open-WebUI)
    @chat {
        path /chat/*
    }
    reverse_proxy @chat http://127.0.0.1:8080

    # Everything else → Hermes WebUI Dashboard :8788 (new dashboard migration)
    reverse_proxy http://127.0.0.1:8788 {
        header_up ngrok-skip-browser-warning "true"
        # Drop duplicate Server header from upstream (dashboard also sets Server)
        header_down -Server
    }
}
