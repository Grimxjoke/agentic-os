:18080 {
	bind 127.0.0.1
	encode zstd gzip

	route {
		# Orbit OS is the only public application. The legacy services remain
		# available for rollback but are no longer routed publicly.
		@root path /
		redir @root /orbit/ 308

		@orbit path /orbit /orbit/*
		reverse_proxy @orbit http://127.0.0.1:4173

		@probes path /healthz /readyz
		reverse_proxy @probes http://127.0.0.1:4173

		respond 404
	}
}
